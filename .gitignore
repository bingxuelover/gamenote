# This .gitignore is appropriate for repositories deployed to Vercel

# Dependencies
node_modules/

# Environment variables and sensitive data
.env
.env.local
.env.*.local
!.env.example

# Vercel specific
.vercel
.vercel/output

# Build outputs
.cache
dist
build
out

# Local development files
*.dev.js
server.js
*.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Documentation (optional)
vercel.md